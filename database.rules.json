{
  "rules": {
    ".read": false,
    ".write": false,
    "fleet": {
      ".read": true,
      ".write": false
    },
    "stats": {
      ".read": true,
      ".write": false
    },
    "pireps": {
      ".read": true,
      ".write": false
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "usersPublic": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "pilotCount": {
      ".read": true,
      ".write": "auth != null"
    },
    "jobsAvailable": {
      ".read": true,
      ".write": "auth != null || root.child('_admin').val() === true"
    },
    "jobsLastSync": {
      ".read": true,
      ".write": "auth != null || root.child('_admin').val() === true"
    }
  }
}
